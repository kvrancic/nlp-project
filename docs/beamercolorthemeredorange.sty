% Red-orange color theme for Gemini beamer poster
% Based on beamercolorthememit.sty

% ====================
% Definitions
% ====================

\definecolor{deepred}{HTML}{8B1A1A}
\definecolor{warmred}{HTML}{B22222}
\definecolor{burntorange}{HTML}{CC5500}
\definecolor{lightorange}{HTML}{FFF4E6}
\definecolor{lightpeach}{HTML}{FFF0E0}
\definecolor{warmgray}{HTML}{F5F0EB}

% Data colors
\definecolor{gain}{HTML}{27ae60}
\definecolor{loss}{HTML}{c0392b}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=deepred}

% Headline
\setbeamercolor{headline}{fg=white,bg=deepred}
\setbeamercolor{headline title}{fg=white}
\setbeamercolor{headline author}{fg=white}
\setbeamercolor{headline institute}{fg=white}
\setbeamercolor{headline rule}{bg=burntorange}

% Block
\setbeamercolor{block title}{fg=burntorange,bg=white}
\setbeamercolor{block separator}{bg=burntorange}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=deepred,bg=lightorange}
\setbeamercolor{block alerted separator}{bg=burntorange}
\setbeamercolor{block alerted body}{fg=black,bg=lightorange}

% Example Block
\setbeamercolor{block example title}{fg=deepred,bg=warmgray}
\setbeamercolor{block example separator}{bg=burntorange}
\setbeamercolor{block example body}{fg=black,bg=warmgray}

% Heading
\setbeamercolor{heading}{fg=deepred}

% Itemize
\setbeamercolor{item}{fg=burntorange}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
